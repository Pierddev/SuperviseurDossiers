# Version

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=superviseur_dossiers

# Microsoft Teams Webhook
TEAMS_WEBHOOK_URL=https://your-teams-webhook.com/...

# Root paths to scan (comma-separated)
# Supports local and network (UNC) paths
CHEMINS_RACINES=C:\,D:\Data,\\NASServer\Share

# Paths to exclude from scanning (comma-separated)
# Subfolders of excluded paths will not be scanned
CHEMINS_EXCLUS=C:\Windows,C:\Program Files,C:\Program Files (x86)

# Time for the daily scan (HH:MM format)
HEURE_SCAN=17:30

# Notification threshold (in MB)
# Only new folders and size variations exceeding this threshold
# will be included in the Teams notification
SEUIL_DEFAUT=100

# Delay between each time check (in seconds, default is 5 minutes)
DELAI_VERIFICATION=300

# Custom thresholds per directory (path=threshold in MB, comma-separated)
# Allows defining a different notification threshold for specific directories.
# Matching is done by prefix: a threshold for D:\Projects applies to D:\Projects\MyPorject as well.
# If a path matches multiple prefixes, the most specific one (longest) wins.
# If empty, all directories use SEUIL_DEFAUT.
SEUILS_PERSONNALISES=D:\Projects=50,D:\Archives=500

# --- Intranet (Web Administration Interface) ---
# Set to 1 to enable the intranet, 0 to disable
INTRANET_ENABLED=0
# Intranet listening port
INTRA_PORT=5000
# Intranet admin credentials
INTRA_ADMIN_USER=admin
INTRA_ADMIN_PWD=your_password
# Secret key for Flask sessions (generate a random key for production)
INTRA_SECRET_KEY=change-me-in-production

# Flask debug mode (Local database)
# Set to 1 to enable debug mode, 0 to disable
FLASK_DEBUG=0
